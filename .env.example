# -----------------------------------------------------------------------------
# ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# Instructions: Copy this file, rename it to ".env", and enter your real keys.
# WARNING: NEVER commit the actual ".env" file to version control (GitHub). (You will need to write it in .gitignore to avoid upload API Keys)
# -----------------------------------------------------------------------------

# OpenAI API Key: Required for accessing GPT models.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY="API_KEY_OPENAI"

# DeepSeek API Key: Required for DeepSeek chat and code services.
# Get yours at: https://platform.deepseek.com/
DEEPSEEK_API_KEY="API_KEY_DEEPSEEK"

# App Environment: Defines the current execution context.
# Values: "development" (local coding), "production" (live server), "test"
ENV="development"